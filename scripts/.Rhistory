library(dagitty)
library(ggdag)
library(ggplot2)
# Define the DAGs
dag1 <- dagitty( 'dag {
"x1"
"x2"
"x3"
"x1" -> "x2"
"x1" -> "x3"
"x2" -> "x3"
}' )
dag2 <- dagitty( 'dag {
"t"
"s"
"e"
"t" -> "s"
"t" -> "e"
}' )
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(dag1, text = FALSE, use_labels = "label") +
geom_node_point(aes(shape = "circle"), color = "black", fill = NA, size = 4) +
geom_node_text(aes(label = label), vjust = 1.6) +
theme_dag()
library(ggplot2)
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(dag1, text = FALSE, use_labels = "label") +
geom_node_text(aes(label = label), vjust = 1.6) +
theme_dag()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(dag1, text = FALSE, use_labels = "label") +
theme_dag()
library(dagitty)
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(dag1) +
theme_dag()
ggdag(dag2) +
theme_dag()
# Define the DAGs
dag1 <- dagitty('dag{x3 <- x1 -> x2 -> x3}')
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(dag1) +
theme_dag()
# Define the DAGs
dag1 <- dagify(x2~x1,
x3~x2+x1)
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(dag1) +
theme_dag()
dag2 <- dagify(s~t,
e~t)
ggdag(dag2) +
theme_dag()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1)) +
theme_dag()
library(dagitty)
ggdag(tidy_dagitty(dag2)) +
theme_dag()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle")
+theme_dag_blank()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle") +
theme_dag_blank()
ggdag(tidy_dagitty(dag2), layout="circle") +
theme_dag_blank()
ggdag(tidy_dagitty(dag2), layout="circle") +
theme_dag_blank()
ggdag(tidy_dagitty(dag2), layout="circle")
ggdag(tidy_dagitty(dag2), layout="circle") +
theme_dag()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle") +
geom_dag_point() +
geom_dag_edges() +
geom_dag_text() +
theme_dag_blank()
ggdag(tidy_dagitty(dag2), layout="circle") +
geom_dag_point() +
geom_dag_edges() +
geom_dag_text() +
theme_dag()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle", label_col = "white") +
geom_dag_point() +
geom_dag_edges() +
geom_dag_text() +
theme_dag_blank()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle", label_col = "white") +
theme_dag_blank()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle", label_col = "white") +
theme_dag()
# Use ggdag to plot the DAGs with empty circles for nodes
ggdag(tidy_dagitty(dag1), layout="circle", label_col = "white", edge_type = "link_arc") +
theme_dag()
library(dagitty)
library(ggdag)
library(ggplot2)
library(stringr)
dag <- dagitty('dag {
bb="-3,-0.5,2,1.2"
"Electricity Usage" [pos="0.177,0.430"]
"Hours Open" [pos="-0.357,0.766"]
"Ice Cream Sales" [pos="-0.892,0.430"]
Temperature [pos="-0.357,0.094"]
Weekend [pos="-0.892,0.766"]
"Hours Open" -> "Electricity Usage"
"Hours Open" -> "Ice Cream Sales"
Temperature -> "Electricity Usage"
Temperature -> "Ice Cream Sales"
Weekend -> "Hours Open"
Weekend -> "Ice Cream Sales"
}
')
dag <- tidy_dagitty(dag)
dag$data$name <- str_replace_all(dag$data$name, fixed(" "), "\n")
dag$data$to <- str_replace_all(dag$data$to, fixed(" "), "\n")
# Use ggdag to plot the DAG
dag_plot <- ggdag(dag, text = FALSE) + theme_dag()
dag_plot <- dag_plot +
geom_text(data = subset(dag$data, name != "Weekend"),
aes(x = x+0.38, y = y, label = name))
dag_plot <- dag_plot +
geom_text(data = subset(dag$data, name == "Weekend"),
aes(x = x, y = y, label = name),
nudge_x = -0.33, nudge_y = 0)
#dag_plot <- ggdag(dag, text = FALSE) +
#  geom_text(data=dag, aes(x=x+0.3, y=y, label=name)) +
#  geom_dag_node(aes(label = ifelse(name == "Weekend", NA, name))) +
#  geom_text(aes(label = ifelse(name == "Weekend", "Weekend", "")),
#            nudge_x = -0.1, nudge_y = 0) +
#  theme_dag()
dag_plot
pdf(file = "../plots/ic_changed_dag.pdf", width = 4, height = 3.5)
