# Elastic net regression
x <- as.matrix(train[, -4])
y <- train[, 4]
elastinet_model <- glmnet(x, y, alpha=0.8)
cv_elastinet <- cv.glmnet(x, y, alpha=0.8)
best_lambda_elastinet <- cv_elastinet$lambda.min
elastinet_coefs <- coef(elastinet_model, s = best_lambda_elastinet)
# Ridge MSE
elasti_predictions <- predict(elastinet_model, newx = as.matrix(test[,-3]), s = best_lambda_elastinet)
elasti_mse <- mse(test$happiness.index, elasti_predictions)
# Random forest
rf_model <- randomForest(happiness.index ~ ., data = train, ntree = 2000, mtry = 3, importance = TRUE)
# Random forest MSE
forest_predictions <- predict(rf_model, test)
forest_mse <- mse(test$happiness.index, forest_predictions)
elastinet_coefs
summary(glm_model)
library(glue)
library(glmnet)
library(readr)
library(purrr)
library(dplyr)
library(boot)
library(Metrics)
library(randomForest)
for (fname in list.files("by_years")) {
assign(glue("df_{substr(fname,0,4)}"), read.csv(glue("by_years/{fname}")))
}
df_list <- list(df_2012,df_2013,df_2015,df_2016,df_2017,df_2018,df_2019,df_2020)
df_list <- lapply(df_list, function(x) x[!(names(x) %in% c("Country"))])
combined <- bind_rows(df_list)
remove_na_cols <- function(df) {
df[, !apply(is.na(df), 2, all)]
}
remove_high_na_cols <- function(df) {
na_proportion <- apply(is.na(df), 2, mean)
df <- df[, na_proportion < 0.4]
return(df)
}
omit_na_based_on_col <- function(df, col) {
df <- df[!is.na(df[[col]]), ]
return(df)
}
combined <- omit_na_based_on_col(combined, col="happiness.index")
combined <- remove_high_na_cols(combined)
combined <- na.omit(combined)
set.seed(815)
combined$id <- 1:nrow(combined)
train <- combined %>% dplyr::sample_frac(0.90)
test  <- dplyr::anti_join(combined, train, by = 'id')
train <- train[,-20]
test <- test[,-20]
#train <- as.data.frame(scale(train))
#test <- as.data.frame(scale(test))
# GLM model
glm_model <- glm(happiness.index ~ ., data = train, family = gaussian())
# GLM MSE
glm_prediction <- predict(glm_model, test)
glm_mse <- mse(test$happiness.index, glm_prediction)
# Elastic net regression
x <- as.matrix(train[, -4])
y <- train[, 4]
elastinet_model <- glmnet(x, y, alpha=0.8)
cv_elastinet <- cv.glmnet(x, y, alpha=0.8)
best_lambda_elastinet <- cv_elastinet$lambda.min
elastinet_coefs <- coef(elastinet_model, s = best_lambda_elastinet)
# Ridge MSE
elasti_predictions <- predict(elastinet_model, newx = as.matrix(test[,-3]), s = best_lambda_elastinet)
elasti_mse <- mse(test$happiness.index, elasti_predictions)
# Random forest
rf_model <- randomForest(happiness.index ~ ., data = train, ntree = 2000, mtry = 3, importance = TRUE)
# Random forest MSE
forest_predictions <- predict(rf_model, test)
forest_mse <- mse(test$happiness.index, forest_predictions)
