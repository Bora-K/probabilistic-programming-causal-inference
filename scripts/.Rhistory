install.packages("dagitty")
# DAG for the first formula
dag1 <- dagitty( 'dag {
"u1" [pos="0,0"]
"u2" [pos="1,1"]
"u3" [pos="2,2"]
"x1" [pos="1,0"]
"x2" [pos="2,1"]
"x3" [pos="3,2"]
"u1" -> "x1"
"u2" -> "x2"
"u3" -> "x3"
"x1" -> "x2"
"x1" -> "x3"
"x2" -> "x3"
}' )
# DAG for the first formula
dag1 <- dagitty('dag {
"u1" [pos="0,0"]
"u2" [pos="1,1"]
"u3" [pos="2,2"]
"x1" [pos="1,0"]
"x2" [pos="2,1"]
"x3" [pos="3,2"]
"u1" -> "x1"
"u2" -> "x2"
"u3" -> "x3"
"x1" -> "x2"
"x1" -> "x3"
"x2" -> "x3"
}' )
# DAG for the second formula
dag2 <- dagitty::dagitty( 'dag {
"u1" [pos="0,0"]
"u2" [pos="1,1"]
"u3" [pos="2,2"]
"t" [pos="1,0"]
"s" [pos="2,1"]
"e" [pos="3,2"]
"u1" -> "t"
"u2" -> "s"
"u3" -> "e"
"t" -> "s"
"t" -> "e"
}' )
# DAG for the first formula
dag1 <- dagitty::dagitty('dag {
"u1" [pos="0,0"]
"u2" [pos="1,1"]
"u3" [pos="2,2"]
"x1" [pos="1,0"]
"x2" [pos="2,1"]
"x3" [pos="3,2"]
"u1" -> "x1"
"u2" -> "x2"
"u3" -> "x3"
"x1" -> "x2"
"x1" -> "x3"
"x2" -> "x3"
}' )
print( dag1 )
print(dag1)
plot(dag1)
